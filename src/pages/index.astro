---
import BaseLayout from "@layouts/BaseLayout.astro";

import Biography from "@components/Biography.astro";
import MainLinks from "@components/MainLinks.astro";
import Experience, { allExperiences } from "../components/Experience.astro";
import HeroTopProjects from "@components/img-components/Hero-Top-Projects.astro";
// BLOG - NOTES
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";
import CardBlog from "@components/CardBlog.astro";
import PreviousPosts from "@components/PreviousPosts.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const last_posts = posts.slice(0, 3);
---

<BaseLayout title="Edgar Delgado Vega - Creative Math Systems Developer">
  <section class="mt-4">
    <h1 class="text-4xl font-bold leading-snug flex">Edgar Delgado</h1>
    <h2 class="py-3 text-xl font-bold text-primary"> Creative Math Systems Developer </h2>
    <HeroTopProjects />
    <div class="mt-16 mb-20">
      <Biography />
      <MainLinks contactText="LinkedIn" linkedin="L" github="G" youtube="Y" />
    </div>
    <Experience workExperiences={allExperiences} indices={[0, 1]} />

    <!-- BLOG-NOTES -->
    <h2 class="text-3xl w-full font-bold flex items-center mt-16 mb-10"> Recent Notes </h2>
    {
      last_posts.map((post) => (
        <>
          {/* tags={post.data.tags} */}
          {/* img={post.data.heroImage} */}
          <CardBlog
            pubDate={post.data.pubDate}
            title={post.data.title}
            badge={post.data.badge}
            desc={post.data.description}
            url={"/blog/" + createSlug(post.data.title, post.id) + "/"}
            target="_self"
          />
        </>
      ))
    }
    <PreviousPosts />
  </section>
</BaseLayout>
