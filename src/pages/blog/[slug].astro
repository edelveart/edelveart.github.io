---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { type BlogSchema } from "../../content.config";
import PostLayout from "../../layouts/PostLayout.astro";
import createSlug from "@ts-config-path/lib/createSlug";
import Arrows from "@icons/Arrows.astro";

export async function getStaticPaths() {
  const postEntries = await getCollection("blog");

  const sorted = postEntries.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return sorted.map((entry, index) => {
    const slug = createSlug(entry.data.title, entry.id);

    const prev = sorted[index - 1] ?? null;
    const next = sorted[index + 1] ?? null;

    return {
      params: { slug },
      props: {
        entry,
        prevPost: prev
          ? {
              title: prev.data.title,
              slug: createSlug(prev.data.title, prev.id),
            }
          : null,
        nextPost: next
          ? {
              title: next.data.title,
              slug: createSlug(next.data.title, next.id),
            }
          : null,
      },
    };
  });
}
type NavBar = {
  title?: string | null;
  slug?: string | null;
};
interface Props {
  entry: CollectionEntry<"blog">;
  prevPost: NavBar;
  nextPost: NavBar;
}

const { entry, prevPost, nextPost } = Astro.props;
const post: BlogSchema = entry.data;
const { Content } = await render(entry);
---

<PostLayout
  title={post.title}
  description={post.description}
  pubDate={post.pubDate}
  updatedDate={post.updatedDate}
  badge={post.badge}
  tags={post.tags}
>
  <Content />

  <div class="divider mt-10"></div>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-5">
    {
      prevPost ? (
        <a
          class="group flex w-full min-h-24 items-center gap-3 rounded-md px-3 py-2 transition-colors duration-150 no-underline"
          href={"/blog/" + prevPost.slug}
        >
          <span class="transition-colors duration-150 group-hover:text-primary">
            <Arrows direction="left" />
          </span>

          <div>
            <div class="text-xs opacity-50 font-normal">NEWER POST</div>
            <div
              class="text-base line-clamp-2 transition-colors duration-150
            group-hover:text-primary group-hover:underline underline-offset-2 font-normal"
            >
              {prevPost.title}
            </div>
          </div>
        </a>
      ) : (
        <a
          class="group flex w-full min-h-24 items-center gap-3 rounded-md px-3 py-2 transition-colors duration-150 no-underline"
          href={"/blog/"}
        >
          <span class="transition-colors duration-150 group-hover:text-primary">
            <Arrows direction="left" />
          </span>

          <div>
            <div class="text-xs opacity-50 font-normal">BLOG</div>
            <div
              class="text-base line-clamp-2 transition-colors duration-150
            group-hover:text-primary group-hover:underline underline-offset-2 font-normal"
            >
              Back to blog
            </div>
          </div>
        </a>
      )
    }
    {
      nextPost ? (
        <a
          class="group flex w-full min-h-24 items-center justify-end gap-3 rounded-md px-3 py-2 transition-colors duration-150 no-underline"
          href={"/blog/" + nextPost.slug}
        >
          <div class="text-right">
            <div class="text-xs opacity-50 font-normal">OLDER POST</div>

            <div
              class="text-base line-clamp-2 transition-colors duration-150
             group-hover:text-primary group-hover:underline underline-offset-2 font-normal"
            >
              {nextPost.title}
            </div>
          </div>

          <span class="transition-colors duration-150 group-hover:text-primary">
            <Arrows direction="right" />
          </span>
        </a>
      ) : (
        <div />
      )
    }
  </div>
</PostLayout>
