---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import createSlug from "@ts-config-path/lib/createSlug";
import CardBlog from "@components/CardBlog.astro";
import Arrows from "@icons/Arrows.astro";

import { NAV_LINKS_PAGES, BORDER_INFO, CARD_OP } from "@styles/utilsCSS";

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("blog");
  posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, { pageSize: 5 });
}
import { GET_COLORS_METADATA } from "@styles/utilsCSS";
const { page } = Astro.props as any;
---

<BaseLayout title="Edgar Delgado - Notes" sideBarActiveItemID="NOTES_ACTIVE_PAGE">
  <article class="pb-0 mt-5">
    <div class="mb-5 mt-5" id="Notes">
      <div class="text-3xl w-full font-bold flex items-center"> Notes </div>
    </div>

    {
      page.currentPage === 1 && (
        <section class={`grid gap-4 sm:grid-cols-2 ${BORDER_INFO} mt-10 mb-2`}>
          <div>
            <h3 class={GET_COLORS_METADATA("field notes")}>Field Notes</h3>
            <p class="text-sm">
              Completed experiments, implementations, and reflections around ongoing projects.
            </p>
          </div>

          <div>
            <h3 class={GET_COLORS_METADATA("sketch notes")}>Sketch Notes</h3>
            <p class="text-sm">
              Early ideas, unfinished paths, and mathematical-music questions I am still following.
            </p>
          </div>

          <div>
            <h3 class={GET_COLORS_METADATA("lab notes")}>Lab Notes</h3>
            <p class="text-sm">
              Long-form explorations of mathematical and musical concepts, structures, and ideas.
            </p>
          </div>
        </section>
      )
    }

    {
      page.data.length === 0 ? (
        <div class={`bg-base-200 ${BORDER_INFO} w-full p-4 min-w-full`}>
          <p class="font-bold">Sorry!</p>
          <p>There are no blog posts to show at the moment. Check back later!</p>
        </div>
      ) : (
        <div class="mt-10">
          {page.data.map((post) => (
            <CardBlog
              title={post.data.title}
              url={"/blog/" + createSlug(post.data.title, post.id)}
              img={post.data.heroImage}
              desc={post.data.description}
              target="_self"
              badge={post.data.badge}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
            />
          ))}
        </div>
      )
    }
  </article>
  <section class=`text-sm mb-8 ${BORDER_INFO}` }>
    <h3 class={GET_COLORS_METADATA("warning")}>AI Assistance</h3>
    <p class={CARD_OP.parr}>
      AI tools are used to assist with grammar, translation, and occasional discussion of ideas.
      Final review remains with the author.
    </p>
  </section>
  <div class="divider mt-10"></div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-5">
    {
      page.url.prev ? (
        <a class={`${NAV_LINKS_PAGES.aLink} ${NAV_LINKS_PAGES.prevLeft}`} href={page.url.prev}>
          <span class={NAV_LINKS_PAGES.arrowSpan}>
            <Arrows direction="left" />
          </span>

          <div>
            <div class={NAV_LINKS_PAGES.prevNext}>NEWER</div>
            <div class={NAV_LINKS_PAGES.pageTitle}>Recent notes</div>
          </div>
        </a>
      ) : (
        <a class={`${NAV_LINKS_PAGES.aLink} ${NAV_LINKS_PAGES.prevLeft}`} href={"/"}>
          <span class={NAV_LINKS_PAGES.arrowSpan}>
            <Arrows direction="left" />
          </span>

          <div>
            <div class={NAV_LINKS_PAGES.prevNext}>HOME</div>
            <div class={NAV_LINKS_PAGES.pageTitle}>Back to homepage</div>
          </div>
        </a>
      )
    }

    {
      page.url.next ? (
        <a class={`${NAV_LINKS_PAGES.aLink} ${NAV_LINKS_PAGES.nextRight}`} href={page.url.next}>
          <div class="text-right">
            <div class={NAV_LINKS_PAGES.prevNext}>OLDER</div>
            <div class={NAV_LINKS_PAGES.pageTitle}>Earlier notes</div>
          </div>

          <span class={NAV_LINKS_PAGES.arrowSpan}>
            <Arrows direction="right" />
          </span>
        </a>
      ) : (
        <div />
      )
    }
  </div>
</BaseLayout>
