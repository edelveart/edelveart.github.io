---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import createSlug from "@ts-config-path/lib/createSlug";
import Arrows from "@icons/Arrows.astro";

const docs = await getCollection("figurate");
// const sortedDocs = docs.sort((a, b) => a.data.order - b.data.order);

const docsMap = Object.fromEntries(docs.map((d) => [d.data.title, d]));
const OVERVIEW = docsMap["Getting Started"];
const THEORY = docsMap["Fundamentals"];
const API = docsMap["API: PlaneFigurateNum"];
const CONTRIBUTING = docsMap["Contributing"];

const CARD_BUTTONS = {
  container:
    "p-4 rounded-md flex flex-col h-full min-h-52 border border-base-content/10 rounded-lg",

  title: "text-lg font-bold",

  paragraps: "mt-2 text-sm opacity-80 mb-4",

  //   btns: "btn btn-ghost border border-base-content/10 rounded-md h-12 mt-auto justify-center font-bold transition-colors duration-200 hover:bg-base-200 hover:border-primary/20",

  btns: `flex items-center justify-center h-12 mt-auto
    rounded-md border border-base-content/10
    text-sm font-normal
    transition-colors duration-150
     hover:border-primary/20 hover:text-primary
    no-underline`,
};
---

<BaseLayout
  title="Edgar Delgado - FigurateNum Documentation"
  sideBarActiveItemID="FIGURATENUM_ACTIVE_PAGE"
>
  <article class="pb-3 mt-5">
    <div class="mb-5 mt-5" id="FIGURATENUM-HOME">
      <div class="flex items-center gap-6">
        <!-- Texto -->
        <h1 class="text-3xl w-full font-black flex flex-col">
          FigurateNum
          <span class="block text-sm uppercase tracking-widest mt-1 text-primary/80">
            Documentation
          </span>
        </h1>
        <!-- <video
          autoplay
          loop
          muted
          playsinline
          id="figurate-video"
          class="w-20 h-20 object-contain p-0 m-0"
        >
          <source src="/svg-ggb/figuratenum/evolution.webm" type="video/webm" />
        </video>Video -->
      </div>
    </div>

    <div class="flex flex-wrap gap-2 mt-4">
      <a
        class="badge badge-outline text-accent/60 hover:text-accent/80 ease-in-out duration-150"
        href="https://pypi.org/project/figuratenum/"
        target="_blank"
        rel="noopener noreferrer"
      >
        PyPI
      </a>
      <a
        class="badge badge-outline text-accent/60 hover:text-accent/80 ease-in-out duration-150"
        href="https://github.com/edelveart/figuratenum"
        target="_blank"
        rel="noopener noreferrer"
      >
        Source Repository
      </a>
      <a
        class="badge badge-outline text-accent/60 hover:text-accent/80 ease-in-out duration-150"
        href="https://doi.org/10.5281/zenodo.18250313"
        target="_blank"
        rel="noopener noreferrer"
      >
        DOI (Zenodo)
      </a>
    </div>

    <p class="mb-4 mt-10 text-balance">
      <strong>FigurateNum</strong> generates and visualizes 235+ plane, space, and multidimensional figurate
      number sequences and families, from polygonal numbers to Platonic solids and higher-dimensional
      analogues.
    </p>

    <p class="mt-3 mb-4">
      Built on definitions from
      <a
        class="text-primary underline text-balance"
        href="https://doi.org/10.1142/8188"
        target="_blank"
        rel="noopener noreferrer"
      >
        Deza & Deza (2012)</a
      >, every sequence is deterministic and reproducible. Optional visualization tools cover phase
      portraits and modular patterns.
    </p>

    <!-- - Sequence generation (lazy iterators) in $\mathbb{Z}$
- Parametric families of sequences
- Visualization in $\mathbb{C}$ using `ComplexViz`
- Modular visualization in $\mathbb{Z}/n\mathbb{Z}$ using `DiscreteViz` -->

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mt-10">
      <div class={CARD_BUTTONS.container}>
        <h2 class={CARD_BUTTONS.title}>Learn from Scratch</h2>
        <p class={CARD_BUTTONS.paragraps}>
          Start with sequence generation and work through parametric families, higher dimensions,
          and visualization tools.
        </p>
        {
          OVERVIEW && (
            <a
              class={CARD_BUTTONS.btns}
              href={"/figuratenum/" + createSlug(OVERVIEW.data.title, OVERVIEW.id)}
            >
              Start here <Arrows direction="right" />
            </a>
          )
        }
      </div>

      <div class={CARD_BUTTONS.container}>
        <h2 class={CARD_BUTTONS.title}>Mathematical Theory</h2>
        <p class={CARD_BUTTONS.paragraps}>
          Explore the basic definitions, notation, and core ideas behind figurate numbers and their
          geometric interpretations.
        </p>
        {
          THEORY && (
            <a
              class={CARD_BUTTONS.btns}
              href={"/figuratenum/" + createSlug(THEORY.data.title, THEORY.id)}
            >
              Explore theory <Arrows direction="right" />
            </a>
          )
        }
      </div>

      <div class={CARD_BUTTONS.container}>
        <h2 class={CARD_BUTTONS.title}>API Reference</h2>
        <p class={CARD_BUTTONS.paragraps}>
          Auto-generated reference for all sequence generators, ComplexViz, and DiscreteViz,
          organized by dimension.
        </p>
        {
          API && (
            <a
              class={CARD_BUTTONS.btns}
              href={"/figuratenum/" + createSlug(API.data.title, API.id)}
            >
              View API <Arrows direction="right" />
            </a>
          )
        }
      </div>

      <div class={CARD_BUTTONS.container}>
        <h2 class={CARD_BUTTONS.title}>Contributing</h2>
        <p class={CARD_BUTTONS.paragraps}>
          Run tests, add new sequences, correct mathematical errata, and submit pull requests.
        </p>
        {
          CONTRIBUTING && (
            <a
              class={CARD_BUTTONS.btns}
              href={"/figuratenum/" + createSlug(CONTRIBUTING.data.title, CONTRIBUTING.id)}
            >
              Contribute <Arrows direction="right" />
            </a>
          )
        }
      </div>
    </div>
  </article>
  <div class="divider mt-10"></div>
  <div class="grid grid-cols-1 gap-2 mt-5">
    {
      OVERVIEW && (
        <a
          class="group flex w-full min-h-24 items-center justify-end gap-3 rounded-md px-3 py-2 transition-colors duration-150 no-underline"
          href={"/figuratenum/" + createSlug(OVERVIEW.data.title, OVERVIEW.id)}
        >
          <div class="text-right">
            <div class="text-xs opacity-50 font-normal">NEXT</div>

            <div
              class="text-base line-clamp-2 transition-colors duration-150
             group-hover:text-primary group-hover:underline underline-offset-2 font-normal"
            >
              {OVERVIEW.data.title}
            </div>
          </div>

          <span class="transition-colors duration-150 group-hover:text-primary">
            <Arrows direction="right" />
          </span>
        </a>
      )
    }
  </div>
</BaseLayout>

<style>
  .post-title {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-title::after {
    content: " #";
    opacity: 0;
    margin-left: 0.5rem;
    color: currentColor;
    text-decoration-line: none;
    display: inline-block;
    transition: opacity 0.2s;
  }

  .post-title:hover::after {
    opacity: 1;
  }

  /* a {
    text-decoration-thickness: 1px;
    text-underline-offset: 8px;
  } */
</style>

