---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import createSlug from "@ts-config-path/lib/createSlug";
import Arrows from "@icons/Arrows.astro";

const docs = await getCollection("figurate");
// const sortedDocs = docs.sort((a, b) => a.data.order - b.data.order);

const docsMap = Object.fromEntries(docs.map((d) => [d.data.title, d]));
const OVERVIEW = docsMap["Getting Started"];
const THEORY = docsMap["Theory"];
const API = docsMap["API"];
const CONTRIBUTING = docsMap["Contributing"];

const cardButtons = {
  container: "p-4 border rounded-lg flex flex-col h-full border-current/25",
  paragraps: "mt-2 text-sm opacity-80 mb-6",
  btns: "btn btn-btn rounded-md ease-in-out duration-150 shadow-sm shadow-primary/10 hover:text-primary justify-center font-bold text-base-content h-12 mt-auto",
};
---

<BaseLayout
  title="Edgar Delgado - FigurateNum Documentation"
  sideBarActiveItemID="FIGURATENUM_ACTIVE_PAGE"
>
  <article class="pb-3 mt-5">
    <div class="mb-5 mt-5" id="FIGURATENUM-HOME">
      <h1 class="text-3xl w-full font-black flex flex-col">
        FigurateNum
        <span class="block text-sm uppercase tracking-wider opacity-50"
          >Documentation</span
        >
      </h1>
    </div>

    <div class="flex flex-wrap gap-2 text-sm mt-4">
      <a
        class="badge badge-outline hover:text-primary ease-in-out duration-200"
        href="https://pypi.org/project/figuratenum/"
        target="_blank"
        rel="noopener noreferrer">PyPI</a
      >
      <a
        class="badge badge-outline hover:text-primary ease-in-out duration-200"
        href="https://github.com/edelveart/figuratenum"
        target="_blank"
        rel="noopener noreferrer">Source Repository</a
      >

      <a
        class="badge badge-outline hover:text-primary ease-in-out duration-200"
        href="https://doi.org/10.5281/zenodo.18250313"
        target="_blank"
        rel="noopener noreferrer"
      >
        DOI (Zenodo)
      </a>
    </div>

    <p class="mb-4 mt-10">
      <strong> FigurateNum </strong> is a Python library for working with figurate
      number sequences, from simple shapes like triangles and pyramids to higher-dimensional
      geometries, based on classical definitions studied by
      <a
        class="underline text-primary"
        href="https://doi.org/10.1142/8188"
        target="_blank"
        rel="noopener noreferrer"
      >
        Elena Deza &amp; Michel Deza (2012)
      </a>.
    </p>

    <p class="mt-3 mb-4">
      FigurateNum provides a unified computational framework that resolves
      inconsistent definitions and scattered sources across articles and other
      parts of the literature. It allows users to <strong>generate</strong>,
      <strong>analyze</strong>, and <strong>visualize</strong> more than 235 families
      of figurate numbers through a consistent Python interface.
    </p>

    <!-- - Sequence generation (lazy iterators) in $\mathbb{Z}$
- Parametric families of sequences
- Visualization in $\mathbb{C}$ using `ComplexViz`
- Modular visualization in $\mathbb{Z}/n\mathbb{Z}$ using `DiscreteViz` -->

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-10">
      <div class={cardButtons.container}>
        <h2 class="text-lg font-bold">Learn from Scratch</h2>
        <p class={cardButtons.paragraps}>
          New to figurate numbers? Start with the fundamentals and learn how to
          generate basic sequences and visualizations.
        </p>
        {
          OVERVIEW && (
            <a
              class={cardButtons.btns}
              href={
                "/figuratenum/" + createSlug(OVERVIEW.data.title, OVERVIEW.id)
              }
            >
              START HERE <Arrows direction="right" />
            </a>
          )
        }
      </div>

      <div class={cardButtons.container}>
        <h2 class="text-lg font-bold">&#128679 Mathematical Theory</h2>
        <p class={cardButtons.paragraps}>
          Explore the basic definitions, notation, and core ideas behind
          figurate numbers and their geometric interpretations.
        </p>
        {
          THEORY && (
            <a
              class={cardButtons.btns}
              href={"/figuratenum/" + createSlug(THEORY.data.title, THEORY.id)}
            >
              EXPLORE THEORY <Arrows direction="right" />
            </a>
          )
        }
      </div>

      <div class={cardButtons.container}>
        <h2 class="text-lg font-bold">&#128679 API Reference</h2>
        <p class={cardButtons.paragraps}>
          Browse the available classes, functions, and utilities for generating,
          analyzing, and visualizing figurate number sequences.
        </p>
        {
          API && (
            <a
              class={cardButtons.btns}
              href={"/figuratenum/" + createSlug(API.data.title, API.id)}
            >
              VIEW API <Arrows direction="right" />
            </a>
          )
        }
      </div>

      <div class={cardButtons.container}>
        <h2 class="text-lg font-bold">&#128679 Contributing</h2>
        <p class={cardButtons.paragraps}>
          Learn how to run tests, add new figurate number families, and
          contribute improvements to the project.
        </p>
        {
          CONTRIBUTING && (
            <a
              class={cardButtons.btns}
              href={
                "/figuratenum/" +
                createSlug(CONTRIBUTING.data.title, CONTRIBUTING.id)
              }
            >
              CONTRIBUTE <Arrows direction="right" />
            </a>
          )
        }
      </div>
    </div>
    <!-- <section class="mt-10">
      <h2 class="text-2xl font-bold">Documentation</h2>
      <ul class="flex gap-6 flex-col">
        {
          sortedDocs.map((post) => (
            <li>
              <a href={"/figuratenum/" + createSlug(post.data.title, post.id)}>
                <h2 class="post-title text-base text-primary font-bold pb-2 underline-offset-2">
                  {post.data.title}
                </h2>
                {/* <p class=" text-pretty">{post.data.description}</p> */}
              </a>
            </li>
          ))
        }
      </ul>
    </section> -->

    <section class="mt-10">
      <blockquote class="text-sm">
        <em>
          FigurateNum is a living project. New sequences, visualizations, and
          mathematical territories are on the way.
        </em>
      </blockquote>
    </section>
    <div class="divider mt-10"></div>
    <div class="grid grid-cols-1 gap-2 mt-5">
      {
        OVERVIEW && (
          <a
            class="btn btn-ghost w-full min-h-24 justify-end text-right hover:text-primary"
            href={
              "/figuratenum/" + createSlug(OVERVIEW.data.title, OVERVIEW.id)
            }
          >
            <div>
              <div class="text-base-content/50"> START HERE</div>
              <div class="text-base line-clamp-2 opacity-85">
                {OVERVIEW.data.title}
              </div>
            </div>
            <Arrows direction="right" />
          </a>
        )
      }
    </div>
  </article>
</BaseLayout>

<style>
  .post-title {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-title::after {
    content: " #";
    opacity: 0;
    margin-left: 0.5rem;
    color: currentColor;
    text-decoration-line: none;
    display: inline-block;
    transition: opacity 0.2s;
  }

  .post-title:hover::after {
    opacity: 1;
  }
</style>
