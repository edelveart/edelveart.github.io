---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { type FigurateSchema } from "../../content.config";
import createSlug from "@ts-config-path/lib/createSlug";
import DocsLayout from "@layouts/DocsLayout.astro";
import Arrows from "@icons/Arrows.astro";

export async function getStaticPaths() {
  const posts = await getCollection("figurate");

  const sorted = posts.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((entry, index) => ({
    params: {
      slug: createSlug(entry.data.title, entry.id),
    },
    props: {
      entry,
      index,
      sorted,
    },
  }));
}
interface Props {
  entry: CollectionEntry<"figurate">;
  sorted: CollectionEntry<"figurate">[];
  index: number;
}

const { entry, index, sorted } = Astro.props;
const post: FigurateSchema = entry.data;
const { Content } = await render(entry);

const prevDoc = sorted[index - 1] ?? null;
const nextDoc = sorted[index + 1] ?? null;
---

<DocsLayout title={post.title} description={post.description}>
  <Content />

  <div class="divider mt-10"></div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-5">
    {
      prevDoc ? (
        <a
          class="group flex w-full min-h-24 items-center gap-3 rounded-md px-3 py-2 transition-colors duration-150 no-underline"
          href={"/figuratenum/" + createSlug(prevDoc.data.title, prevDoc.id)}
        >
          <span class="transition-colors duration-150 group-hover:text-primary">
            <Arrows direction="left" />
          </span>

          <div>
            <div class="text-xs opacity-50 font-normal">PREVIOUS</div>
            <div
              class="text-base line-clamp-2 transition-colors duration-150
            group-hover:text-primary group-hover:underline underline-offset-2 font-normal"
            >
              {prevDoc.data.title}
            </div>
          </div>
        </a>
      ) : (
        <a
          class="group flex w-full min-h-24 items-center gap-3 rounded-md px-3 py-2 transition-colors duration-150 no-underline"
          href="/figuratenum"
        >
          <span class="transition-colors duration-150 group-hover:text-primary">
            <Arrows direction="left" />
          </span>

          <div>
            <div class="text-xs opacity-50 font-normal">PREVIOUS</div>
            <div
              class="text-base line-clamp-2 transition-colors duration-150
            group-hover:text-primary group-hover:underline underline-offset-2 font-normal"
            >
              FigurateNum
            </div>
          </div>
        </a>
      )
    }
    {
      nextDoc ? (
        <a
          class="group flex w-full min-h-24 items-center justify-end gap-3 rounded-md px-3 py-2 transition-colors duration-150 no-underline"
          href={"/figuratenum/" + createSlug(nextDoc.data.title, nextDoc.id)}
        >
          <div class="text-right">
            <div class="text-xs opacity-50 font-normal">NEXT</div>

            <div
              class="text-base line-clamp-2 transition-colors duration-150
             group-hover:text-primary group-hover:underline underline-offset-2 font-normal"
            >
              {nextDoc.data.title}
            </div>
          </div>

          <span class="transition-colors duration-150 group-hover:text-primary">
            <Arrows direction="right" />
          </span>
        </a>
      ) : (
        <div />
      )
    }
  </div>
</DocsLayout>
