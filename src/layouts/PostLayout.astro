---
import { type BlogSchema } from "../content.config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";
export interface Props extends BlogSchema {}

const { title, description, pubDate, updatedDate, badge, heroImage, tags = [] } = Astro.props;
dayjs.extend(localizedFormat);
const displayDate = dayjs(pubDate).format("ll");
---

<BaseLayout title={title} description={description} ogType="article">
  <main class="">
    <article class="prose prose-img:mx-auto">
      <h1 class="title mt-5 text-3xl font-bold break-words mb-2 text-primary">
        {title}
      </h1>
      <div class="mb-4">
        {pubDate && <time class="text-md">{displayDate}</time>}
      </div>
      <div class="border-l-4 border-primary pl-4 py-2 mb-12">
        <div class="pl-0 gap-2 flex flex-wrap items-baseline">
          {badge && <div class="text-xs text-primary/60 shrink-0">{badge}</div>}
          {
            tags &&
              tags.map((tag) => (
                <a
                  href={`/blog/tag/${tag}`}
                  class="text-xs text-accent/60 hover:opacity-100 hover:text-accent/80
                  transition-colors duration-150 font-normal underline-offset-2"
                >
                  {tag}
                </a>
              ))
          }
          {
            updatedDate && (
              <div class="">
                Last updated on <time>{updatedDate}</time>
              </div>
            )
          }
        </div>
      </div>
      <div class="prose prose-table:table-xs prose-table:table-zebra">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>
