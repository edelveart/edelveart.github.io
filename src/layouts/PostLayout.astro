---
import { META_BADGE_TAGS } from "@styles/utilsCSS";
import { type BlogSchema } from "../content.config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";
export interface Props extends BlogSchema {}

const { title, description, pubDate, updatedDate, badge, heroImage, tags = [] } = Astro.props;
dayjs.extend(localizedFormat);
const displayDate = dayjs(pubDate).format("ll");
---

<BaseLayout title={title} description={description} ogType="article">
  <main>
    <article class="prose prose-img:mx-auto">
      <h1 class="title mt-5 text-3xl font-bold break-words mb-2 text-primary">
        {title}
      </h1>

      <div class="flex items-center gap-2">
        {pubDate && <time>{displayDate}</time>}
        <span class="text-base-content/60">•</span>
        <span class={META_BADGE_TAGS.badge}>{badge}</span>
        {
          updatedDate && (
            <>
              <span class="text-base-content/60">•</span>
              <span class="text-base-content/70 text-sm">
                Updated {dayjs(updatedDate).format("ll")}
              </span>
            </>
          )
        }
      </div>

      <div class="border-l-4 border-info/70 pl-4 mt-4 mb-10">
        <div class="flex flex-wrap gap-x-2 gap-y-1">
          {
            tags?.map((tag) => (
              <a href={`/blog/tag/${tag}`} class={META_BADGE_TAGS.tags}>
                {tag}
              </a>
            ))
          }
        </div>
      </div>

      <div class="prose-table:overflow-x-auto prose-table:block">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>
