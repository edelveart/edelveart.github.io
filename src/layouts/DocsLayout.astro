---
import BaseLayout from "./BaseLayout.astro";

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="prose prose-img:mx-auto">
    <h1 class="title mt-5 text-3xl font-bold break-words mb-10 text-primary">
      {title}
    </h1>
    <div class="prose-table:table-xs">
      <slot />
    </div>
  </article>
</BaseLayout>
