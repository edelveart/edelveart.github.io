---
import Arrows from "@icons/Arrows.astro";
import { CARD_OP } from "@ts-config-path/styles/utilsCSS";

interface Props {
  key?: number;
  title: string;
  subtitle: string;
  description?: string;
  moreInfo?: string;
}
const { title, subtitle, description }: Props = Astro.props;
---

<div class="group flex">
  <div class="education__time flex flex-col items-center">
    <span class="w-3 h-3 border border-primary/60 rounded-[3px]"></span>
    <span class="flex-1 border-l-2 border-base-content/20"></span>
  </div>

  <div class="experience__data pl-4 pb-4 w-full">
    <details class="group">
      <summary class="cursor-pointer list-none">
        <h3 class=`${CARD_OP.title}  mb-1  transition-colors duration-150 group-hover:text-primary`>
          {title}
        </h3>

        <div class=`${CARD_OP.muteData} flex items-center gap-2 `>
          <span class="">{subtitle}</span>

          {
            description && (
              <span class="transition-transform duration-200 group-open:-rotate-180 group-hover:text-primary">
                <Arrows direction="down" size="sm" />
              </span>
            )
          }
        </div>
      </summary>

      {
        description && (
          <p class={`mt-4 whitespace-pre-line max-w-180 ${CARD_OP.parr}`}>{description}</p>
        )
      }
    </details>
  </div>
</div>
