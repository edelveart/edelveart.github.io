---
export const techSkillsSpanish: string[] = [
  "TypeScript, Node.js, Express, SQL, Git",
  "Cierto conocimiento de Ruby y Python",
  "LaTex, GeoGebra, Zotero, BibTex",
  "Sonic Pi, MuseScore, Reaper",
];

export const techSkillsEnglish: string[] = [
  "TypeScript, Node.js, Express, SQL, Git",
  "Some knowledge of Ruby and Python",
  "LaTex, GeoGebra, Zotero, BibTex",
  "Sonic Pi, MuseScore, Reaper",
];

type Props = {
  indices: number[];
  title: string;
  techSkills: string[];
};

import { BULLET_SQUARE_LIST } from "@ts-config-path/pages/about.astro";

const { indices = [], title, techSkills = [] } = Astro.props;

const filteredSkills = indices
  .map((index) => techSkills[index])
  .filter((skill) => skill !== undefined);
---

<div class="my-10">
  <div class="text-2xl w-full font-bold flex items-center">
    {title}
  </div>
  <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-0.5] pl-2 mt-6">
    {
      filteredSkills.map((skill) => (
        <li class={BULLET_SQUARE_LIST.li}>
          <span class={BULLET_SQUARE_LIST.span} />

          <p>{skill}</p>
        </li>
      ))
    }
  </ul>
</div>
