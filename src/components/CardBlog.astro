---
const { title, img, desc, url, badge, pubDate, tags, target = "_blank" } = Astro.props;
const tag_url = url.split("/").slice(0, -1).join("/") + "/tag";

// PubDATE from md files
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";
dayjs.extend(localizedFormat);
const displayDate = dayjs(pubDate).format("ll");
---

<a
  href={url}
  target={target}
  class="group flex border border-base-content/10 p-4 my-6 rounded-md mx-auto md:min-h-40 flex-col transition-colors duration-150 ease-in-out hover:border-primary/20"
>
  <div class="flex items-center gap-1">
    <span class="text-base-content/80 text-sm">{displayDate}</span>
    <span class="opacity-60 text-sm">▪</span>
    <span class="text-primary/60 text-sm">{badge}</span>
  </div>

  <h2 class="mt-1 text-lg font-semibold group-hover:text-primary line-clamp-2 md:line-clamp-none">
    {title}
  </h2>

  <p class="text-sm mt-2 text-base-content/80 md:line-clamp-none line-clamp-2">
    {desc}
  </p>
</a>
