---
const {
  title,
  img,
  desc,
  url,
  badge,
  pubDate,
  tags,
  target = "_blank",
} = Astro.props;
const tag_url = url.split("/").slice(0, -1).join("/") + "/tag";

import Arrows from "@icons/Arrows.astro";
// PubDATE from md files
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";
dayjs.extend(localizedFormat);
const displayDate = dayjs(pubDate).format("ll");
---

<div class="rounded-lg bg-base-100 px-0 my-10">
  <div class="flex-col md:flex-row">
    <div class="grow w-full">
      <h1 class="text-2xl font-bold flex flex-row pb-3 mt-4 text-primary">
        {title}
      </h1>
      {pubDate && <time class="text-sm">{displayDate}</time>}
      <p class="py-4 text-md mb-3">{desc}</p>
      <!-- <div class="card-actions justify-start mt-3 gap-3 items-baseline">
        {
          tags &&
            tags.map((tag) => (
              <a
                href={`${tag_url}/${tag}`}
                class="badge badge-neutral badge-sm rounded-md p-3 hover:badge-secondary  ease-in-out duration-200 "
              >
                {tag}
              </a>
            ))
        }
      </div> -->
      <a
        href={url}
        target={target}
        class="btn bg-inherit py-6 text-base rounded-md hover:shadow-primary/40 ease-in-out duration-150 mt-0 shadow-sm shadow-primary/20 w-32 justify-center gap-x-1.5 transition"
      >
        Read
        <Arrows direction="right" />
      </a>
    </div>
  </div>
</div>
