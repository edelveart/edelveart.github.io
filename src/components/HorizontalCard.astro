---
const { title, img, desc, url, badge, tags, target = "_blank" } = Astro.props;
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
const tag_url = url.split("/").slice(0, -1).join("/") + "/tag";

export type ProjectType = {
  title: string;
  img: ImageMetadata | string;
  desc: string;
  url: string;
  badge: string;
};
import { CARD_OP, GET_COLORS_METADATA } from "@styles/utilsCSS";
---

<div
  class="group rounded-md transition-colors ease-in-out duration-150 border border-base-content/10 hover:border-primary/20"
>
  <a href={url} target={target} rel="noopener">
    <div class="hero-content flex-col md:flex-row p-4">
      <div class="grow w-full">
        <span class={GET_COLORS_METADATA("cardsImg")}>{badge}</span>
        <h1 class=`${CARD_OP.title} mt-0.5 group-hover:text-primary`>
          {title}
        </h1>

        <p class=`text-balance pt-2 ${CARD_OP.parr}`>{desc}</p>
      </div>
      {
        img && (
          <Image
            src={img}
            width={750}
            height={422}
            format="webp"
            alt={title}
            class="max-w-full md:max-w-52 rounded-lg"
          />
        )
      }
    </div>
  </a>
</div>
