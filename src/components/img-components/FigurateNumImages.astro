---
import { Image } from "astro:assets";
import discreteAndContinuousPortraits from "../../assets/libraries-webp/discrete-continuous-portraits.webp";
---

<figure class="text-center my-10 text-gray-400">
  <Image
    src={discreteAndContinuousPortraits}
    alt="Picture of 5D Hyperoctahedron (Discrete and Continuous)"
    class="w-[85%] mx-auto rounded-lg"
    loading="lazy"
    fetchpriority="high"
  />
  <figcaption class="mt-3 text-sm text-gray-400">
    <span
      >Figurate Number 5D Hyperoctahedron: Discrete mod M (left) vs. Continuous Meromorphic Portrait
      (right)
    </span>
  </figcaption>
</figure>
