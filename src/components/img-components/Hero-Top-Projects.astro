---
import { allProjects } from "@components/ProjectsComponent.astro";
import { Image } from "astro:assets";

const divisor = "my-6";
const UrlArray = allProjects;

const cardDisplay = "aspect-[16/8]";
const imagePadding = "p-0";
const cardBase = `
  block relative w-full ${cardDisplay}
  max-h-72 rounded-md
  ${imagePadding}
  border border-base-content/10
  shadow-sm shadow-black/5
  transition-colors duration-150 ease-in-out
  hover:border-primary/20
  hover:shadow-primary/20
`;

import { META_BADGE_TAGS } from "@styles/utilsCSS";
const badge = `absolute bottom-0 right-0 m-4 p-1 bg-base-100/50 rounded-md text-xs ${META_BADGE_TAGS.badge} z-10`;

import MainFigurateNumImage from "@assets/main-figuratenum.webp";
import MainTonnetzImage from "@assets/main-tonnetz.webp";
import MainModularImage from "@assets/main-modular.webp";
---

<div class={divisor}></div>
<a href={UrlArray[2].url} target="_blank" rel="noopener noreferrer" class={cardBase}>
  <div class={badge}>
    <span>FigurateNum • PyPI</span>
  </div>

  <Image
    src={MainFigurateNumImage}
    class="w-full h-full object-cover rounded-md"
    width={400}
    height={200}
    format="webp"
    priority
    alt="FigurateNumber - Phase Portrait"
  />
</a>

<div class={divisor}></div>

<section class="grid grid-cols-1 lg:grid-cols-2 gap-x-4 gap-y-8">
  <a href={UrlArray[1].url} target="_blank" rel="noopener noreferrer" class={cardBase}>
    <div class={badge}>
      <span>Modular Forms • RubyGems</span>
    </div>
    <Image
      src={MainModularImage}
      class="w-full h-full object-cover invert hue-rotate-270 rounded-md will-change-[filter]"
      width={400}
      height={200}
      format="webp"
      loading="lazy"
      fetchpriority="low"
      alt="Math-Modular-Elliptic-Image"
    />
  </a>
  <a href={UrlArray[0].url} target="_blank" rel="noopener noreferrer" class={cardBase}>
    <div class={badge}>
      <span>TS-Tonnetz • npm</span>
    </div>
    <Image
      src={MainTonnetzImage}
      alt="ts-tonnetz simplices portrait"
      class="w-full h-full object-cover invert hue-rotate-180 rounded-md will-change-[filter]"
      width={400}
      height={200}
      format="webp"
      loading="lazy"
      fetchpriority="low"
    />
  </a>
</section>
