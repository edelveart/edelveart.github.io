---
import SideBarMenu from "@components/es/SideBarMenu.astro";
// import SideBarFooter from "@components/SideBarFooter.astro";
import PhotoProfile from "@components/img-components/PhotoProfile.astro";
import LinkIconsGroup from "@components/LinkIconsGroup.astro";

export const menuSpanish = {
  homeMenu: {
    text: "Inicio",
    href: "/es",
  },
  projectsMenu: {
    text: "Bibliotecas",
    href: "/es/projects",
  },
  cvMenu: {
    text: "Acerca de mí",
    href: "/es/about",
  },
  resourcesMenu: {
    text: "Recursos",
    href: "/es/resources",
  },
  figurateMenu: {
    text: "FigurateNum",
    href: "/figuratenum",
  },
};
---

<div class="drawer-side z-40" id="sidebar-scroll-container">
  <label for="my-drawer" class="drawer-overlay"></label>
  <aside
    class="px-2 pt-2 h-full min-h-full w-72 max-w-72 bg-base-100 text-base-content flex flex-col"
  >
    <div class="w-fit mx-auto mt-5 mb-6">
      <a href="/">
        <div class="avatar transition ease-in-out hover:scale-[102%] block m-auto">
          <div class="w-32">
            <PhotoProfile />
          </div>
        </div>
      </a>
    </div>

    <SideBarMenu
      homeMenu={menuSpanish.homeMenu.text}
      hrefHome={menuSpanish.homeMenu.href}
      cvMenu={menuSpanish.cvMenu.text}
      hrefCV={menuSpanish.cvMenu.href}
      projectsMenu={menuSpanish.projectsMenu.text}
      hrefProjects={menuSpanish.projectsMenu.href}
      resourcesMenu={menuSpanish.resourcesMenu.text}
      hrefResources={menuSpanish.resourcesMenu.href}
      figurateMenu={menuSpanish.figurateMenu.text}
      hrefFigurate={menuSpanish.figurateMenu.href}
    />
    <footer
      class="footer footer-center flex justify-center-safe gap-x-1 items-center pt-0 mt-auto mb-6"
    >
      <LinkIconsGroup />
    </footer>
  </aside>
</div>
