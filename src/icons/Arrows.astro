---
type Props = {
  direction?: "left" | "right" | "down";
  size?: "sm" | "md" | "lg";
};

const { direction = "right", size = "md" }: Props = Astro.props;

const sizeClass =
  size === "sm" ? "h-6 w-6" : size === "lg" ? "h-8 w-8 md:h-10 md:w-10" : "h-6 w-6 md:h-8 md:w-8";

const rotationClass = direction === "left" ? "rotate-180" : direction === "down" ? "rotate-90" : "";
---

<svg
  class={`shrink-0 fill-current ${sizeClass} ${rotationClass}`}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
>
  <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"></path>
</svg>
