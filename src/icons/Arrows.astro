---
type Props = {
  direction?: "left" | "right" | "down" | "up";
  size?: "sm" | "md" | "lg";
};

const { direction = "right", size = "md" }: Props = Astro.props;
const sizeClass = {
  sm: "h-4 w-4",
  md: "h-4 w-4",
  lg: "h-4 w-4 md:h-5 md:w-5",
}[size];

const rotationClass = {
  right: "",
  down: "rotate-90",
  left: "rotate-180",
  up: "-rotate-90",
}[direction];
---

<svg
  class={`shrink-0 ${sizeClass} ${rotationClass}`}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 16 16"
  fill="currentColor"
>
  <path
    d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"
  >
  </path>
</svg>
