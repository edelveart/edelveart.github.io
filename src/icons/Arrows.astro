---
type Props = {
  direction: "left" | "right";
  size?: "sm" | "md" | "lg";
};

const { direction = "right", size = "md" }: Props = Astro.props;

const sizeClass =
  size === "sm" ? "h-6 w-6" : size === "lg" ? "h-8 w-8 md:h-10 md:w-10" : "h-6 w-6 md:h-8 md:w-8";
---

{
  direction === "left" ? (
    <svg
      class={`shrink-0 fill-current ${sizeClass}`}
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
    >
      <path d="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" />
    </svg>
  ) : (
    <svg
      class={`shrink-0 fill-current ${sizeClass}`}
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
    >
      <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
    </svg>
  )
}
